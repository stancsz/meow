{
  "name": "meow",
  "version": "0.1.0",
  "description": "High-performance, local-first autonomous agent workstation",
  "main": "apps/desktop/main.cjs",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "meow": "packages/kernel/cli/index.ts",
    "claude": "claude.cmd",
    "meow-chan": "packages/harness/relay.ts"
  },
  "devDependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@types/screenshot-desktop": "^1.15.0",
    "chalk": "^5.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "next": "^14.2.3",
    "tsx": "^4.19.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run packages/kernel/cli/index.ts",
    "meow-chan": "bun run packages/kernel/cli/index.ts --meow-chan",
    "meow-chan:mention": "bun run packages/kernel/cli/index.ts --meow-chan-mention",
    "channels": "bun run packages/harness/relay.ts",
    "channels:mention": "bun run packages/harness/relay.ts --mention-only",
    "channels:stop": "bash run-relay.sh --stop",
    "channels:status": "bash run-relay.sh --status",
    "channels:watch": "bash run-relay.sh --watch --mention-only",
    "start:server": "bun run --allow-read=./workspace --allow-net=api.anthropic.com,mcp-gateway.internal --permission-deny-sys src/index.ts --mode=server",
    "start:hybrid": "bun run --allow-read=./workspace --allow-net=api.anthropic.com,mcp-gateway.internal --permission-deny-sys src/index.ts --mode=hybrid",
    "test": "bun test && cd apps/dashboard && bun test --preload ./setupTests.ts",
    "test:integration": "bun test src/core/integration.test.ts",
    "test:integration:workflow": "bun test src/core/orchestrator.integration.test.ts",
    "test:integration:all": "bun test src/tests/integration/",
    "test:plugins": "./scripts/test-plugins.sh",
    "test:heartbeat": "bun test src/core/heartbeat.test.ts",
    "heartbeat": "bun run scripts/heartbeat-simulator.ts",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build:dashboard && electron-builder",
    "build:dashboard": "cd apps/dashboard && npm run build",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@jackwener/opencli": "^1.5.2",
    "@supabase/supabase-js": "^2.101.1",
    "@types/express": "^5.0.6",
    "agent-browser": "^0.17.1",
    "better-sqlite3": "^12.8.0",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "happy-dom": "^20.8.4",
    "openai": "^6.34.0",
    "screenshot-desktop": "^1.15.3",
    "stripe": "^21.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.meow.agent",
    "productName": "Meow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/desktop/**/*",
      "apps/dashboard/**/*",
      "src/**/*",
      "cli/**/*",
      ".agents/**/*",
      "!**/node_modules/**/*",
      "!**/.next/**/*",
      "!**/dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "zip"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stancsz/meow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/stancsz/agent-kernel/issues"
  },
  "homepage": "https://github.com/stancsz/meow#readme"
}
