{
  "name": "@agent-kernel/agent-harness",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run index.ts",
    "meow-chan": "bun run relay.ts",
    "meow-chan:mention": "bun run relay.ts --mention-only",
    "relay": "bun run relay.ts",
    "relay:mention": "bun run relay.ts --mention-only",
    "build": "bun build index.ts --outdir=dist --format=esm --target=node",
    "docker:build": "docker build -t meow-bridge .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "discord.js": "^14.15.3",
    "openai": "^4.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "bun-types": "^1.1.0"
  }
}

