# 🦀 SimpleClaw Environment Configuration Example

# ==========================================
# 🔴 LLM PROVIDER API KEYS
# ==========================================
# SimpleClaw supports multiple LLM providers. Set at least one.

# OpenAI API Key for the Agent's brain
# Get yours at https://platform.openai.com/
OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key (Claude)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek API Key
# Get yours at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# Gemini API Key
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# ==========================================
# 🟢 OPTIONAL / RECOMMENDED SETTINGS
# ==========================================

# AI Model Configuration (OpenAI Compatible)
# Defaults to https://api.openai.com/v1 if not set
OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# 🟡 LOCAL LLM PROVIDERS
# ==========================================
# Configure if using local models (Ollama, LM Studio)

# Ollama Base URL (for local models like llama3, mistral, etc.)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio Base URL (for local models via LM Studio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Discord Integration (Required if ENABLE_DISCORD is true)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-channel-id

# Plugin Activation (Set to 'true' to enable)
ENABLE_DISCORD=false
ENABLE_WHATSAPP=false
ENABLE_MESSENGER=false
ENABLE_BROWSER=true
ENABLE_GITHUB=true
ENABLE_GDRIVE=true
ENABLE_LINEAR=true
ENABLE_SCREENCAP=true

# Database Mode
# Set to 'true' to use local SQLite instead of Supabase
LOCAL_MODE=true

# Worker Management (Used for managed node scaling)
# Only needed if running as a remote worker
MANAGEMENT_API_URL=http://localhost:3000
MANAGEMENT_API_KEY=your-secret-management-key

# ==========================================
# 🔘 SUPABASE SETTINGS (Optional - Only if LOCAL_MODE=false)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-key

# ==========================================
# 💳 STRIPE PAYMENTS (Phase 1 Gas Tank)
# ==========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
