# Claude Bridge Docker Environment Variables
# Copy this to .env and fill in the values

# Discord bot token (required)
DISCORD_TOKEN=

# Anthropic API configuration (required for Claude Code)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# GitHub Personal Access Token (for git clone operations)
GH_PAT=

# Optional: Working directory for Claude Code (default: /app)
# CLAUDE_CWD=/app

# Optional: Channel IDs to watch (comma-separated, leave empty for all)
# RELAY_CHANNELS=

# Optional: Message prefix to trigger relay
# RELAY_PREFIX=

# Optional: Set to "1" for mention-only mode
# RELAY_MENTION_ONLY=

# Optional: Claude request timeout in ms (default: 3600000 = 1 hour)
# CLAUDE_TIMEOUT_MS=3600000

# Optional: Disable non-essential traffic to reduce costs
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Show typing indicator (default: "1")
# RELAY_TYPING=1
